{
    "name": "obsidian-vim-motions",
    "version": "0.1.0",
    "description": "Enhances Obsidian's Vim mode with Markdown-aware text objects, structural navigation, workspace keyboard control, and a polished Neovim-native experience.",
    "main": "main.js",
    "type": "module",
    "scripts": {
        "dev": "node esbuild.config.mjs",
        "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
        "version": "node version-bump.mjs && git add manifest.json versions.json",
        "lint": "eslint .",
        "test:e2e": "wdio run ./wdio.conf.mts",
        "test": "npm run build && npm run test:e2e"
    },
    "keywords": [],
    "license": "MIT",
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@types/mocha": "^10.0.10",
        "@types/node": "^22.15.17",
        "@wdio/cli": "^9.28.0",
        "@wdio/globals": "^9.28.0",
        "@wdio/local-runner": "^9.28.0",
        "@wdio/mocha-framework": "^9.28.0",
        "esbuild": "0.25.5",
        "eslint": "^9.39.4",
        "eslint-plugin-obsidianmd": "^0.3.0",
        "globals": "^17.6.0",
        "jiti": "^2.6.1",
        "mocha": "^11.7.6",
        "obsidian": "latest",
        "typescript": "^5.8.3",
        "typescript-eslint": "^8.59.1",
        "wdio-obsidian-reporter": "^3.1.1",
        "wdio-obsidian-service": "^3.1.1"
    }
}
